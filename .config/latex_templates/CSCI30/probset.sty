%% CSCI 30 macros
% Pseudocode
\usepackage{stmaryrd}
\renewcommand{\algorithmicrequire}{\textbf{Input:}}
\renewcommand{\algorithmicensure}{\textbf{Output:}}
% \renewcommand{\algorithmicfunction}{\textbf{algorithm}}
\newcommand{\Proc}[2]{\item[\textproc{#1}(#2):]}
\renewcommand{\algorithmicfunction}{}
\renewcommand{\Return}[1]{\State \textbf{return} #1}
\algnewcommand\algorithmicforeach{\textbf{for each}}
\algdef{S}[FOR]{ForEach}[1]{\algorithmicforeach\ #1\ \algorithmicdo}
% \algrenewcommand{\algorithmiccomment}[1]{\hfill$\sslash$ #1}
\algrenewcommand{\algorithmiccomment}[1]{\hfill\textbf{\texttt{/\hspace*{-3pt}/}} #1}
\newcommand{\Break}{\State \textbf{break}}
\newcommand{\algtrue}{\textsc{true}}
\newcommand{\algfalse}{\textsc{false}}
\newcommand{\algnull}{\textsc{null}}
\newcommand{\Id}[1]{\textit{#1}}
\MakeRobust{\Call}

% suppress do, then
\algrenewcommand\algorithmicthen{}
\algrenewcommand\algorithmicdo{}
% new operators
\newcommand{\append}{\mathrel{\hspace{1pt}++\hspace{1pt}}}
\newcommand{\cons}{\mathrel{\hspace{1pt}:\hspace*{0.8pt}:\hspace{1pt}}}
\newcommand{\booland}{\mathrel{\hspace{1pt}\text{and}\hspace{1pt}}}
\newcommand{\Or}{\mathrel{\hspace{1pt}\text{or}\hspace{1pt}}}
\newcommand{\In}{\ifmmode\ \textrm{\textbf{in}}\ \else\textbf{in}\ \fi}
% yoinked from clrscode
\def\gets{\mathrel{\hspace{1pt}=\hspace{1pt}}}
\newcommand{\isequal}{\mathrel{\scalebox{0.6}[1]{=}\hspace*{0.1pt}\scalebox{0.6}[1]{=}}}
\newcommand{\To}{\ifmmode\ \textrm{\textbf{to}}\ \else\textbf{to}\ \fi}
\newcommand{\By}{\ifmmode\ \textrm{\textbf{by}}\ \else\textbf{by}\ \fi}
\newcommand{\Downto}{\ifmmode\ \textrm{\textbf{downto}}\ \else\textbf{downto}\ \fi}

